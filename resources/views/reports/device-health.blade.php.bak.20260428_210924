            <tbody>
            @forelse($devices as $d)
                @php
                    $score = (int) $d->total_tickets;
                    $health = $score > 10 ? 'BAD' : ($score > 5 ? 'WARNING' : 'GOOD');
                    $class = $health === 'BAD' ? 'bad' : ($health === 'WARNING' ? 'warn' : 'good');
                @endphp
                <tr>
                    <td>{{ $d->device_id ?: 'No Device' }}</td>
                    <td>{{ $d->total_tickets }}</td>
                    <td>{{ $d->open }}</td>
                    <td>{{ $d->closed }}</td>
                    <td>{{ $d->last_issue }}</td>
                    <td><span class="pill {{ $class }}">{{ $health }}</span></td>
                </tr>
            @empty
                <tr><td colspan="6" style="text-align:center;color:#64748b;padding:30px;">No ticket data yet.</td></tr>
            @endforelse
            </tbody>
        </table>
    </div>
