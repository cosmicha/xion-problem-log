    public function take(ProblemLog $problemLog)
    {
        $user = auth()->user();

        if ($user->role !== 'engineer') {
            abort(403);
        }

        $oldStatus = $problemLog->status;

        $problemLog->update([
            'assigned_engineer_id' => $user->id,
            'engineer_name' => $user->name,
            'assigned_by_user_id' => $problemLog->assigned_by_user_id ?: $user->id,
